# =============================================================================
# VirtualRadio Backend - Environment variables (copy to .env)
# =============================================================================

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production
API_VERSION=1.0.0

# JWT (seconds)
JWT_SECRET_KEY=change-me-too
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Database (PostgreSQL 18). Inside docker-compose the host is "db".
DATABASE_URL=postgresql+psycopg://virtualradio:virtualradio@db:5432/virtualradio

# Redis 8 (Celery broker / result backend + caches). Host "redis" in compose.
REDIS_URL=redis://redis:6379/0

# Media volume (input music, TTS cache, FX, exported episodes)
MEDIA_ROOT=/data/media

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# AI / TTS providers (optional: the pipeline degrades gracefully without them)
GEMINI_API_KEY=
OPENROUTER_API_KEY=
LLM_MODEL=google/gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
LLM_TIMEOUT=20

# Vertex AI via Application Default Credentials (ADC) — alternative to GEMINI_API_KEY.
# Set GEMINI_USE_VERTEX=true and provide your GCP project + location. The ADC file
# (created by `gcloud auth application-default login`) is mounted into the
# containers from ADC_PATH.
GEMINI_USE_VERTEX=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
ADC_PATH=${HOME}/.config/gcloud/application_default_credentials.json

# Retention (days) for finished generation_jobs cleanup
JOBS_RETENTION_DAYS=7
